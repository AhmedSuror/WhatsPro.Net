{
  "metadata": [
    {
      "src": [
        {
          "files": [
            "src/WhatsPro/WhatsPro.csproj"
          ]
        }
      ],
      "dest": "docs/CoreSDK/api"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "docs/**.yml",
          "docs/**.md",
          "docs/**/toc.yml",
          "toc.yml",
          "*.md"
        ],
        "exclude": [
          "obj/**",
          "bin/**",
          "_site/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**",
          "favicon.png",
          "logo.png"
        ]
      }
    ],
    "dest": "_site",
    "globalMetadata": {
      "_appFaviconPath": "favicon.png",
      "_appName": "WhatsPro.Net"
    },
    "globalMetadataFiles": [],
    "fileMetadataFiles": [],
    "template": [
      "default",
      "modern"
    ],
    "postProcessors": [],
    "keepFileLink": false,
    "cleanupCacheHistory": false,
    "disableGitFeatures": false
  }
}
